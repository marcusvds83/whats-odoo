# WhatsApp-Odoo Middleware - Environment Variables

# ============================================================
# LOCAL DESENVOLVIMENTO
# ============================================================
DATABASE_URL=file:./dev.db
NODE_ENV=development
ODOO_SERVICE_URL=http://localhost:3002
PORT=3000

# ============================================================
# RENDER PRODUÇÃO (preencha no painel do Render)
# ============================================================
# DATABASE_URL=file:/opt/render/project/src/data/whats-odoo.db
# NODE_ENV=production
# PORT=10000
# HOSTNAME=0.0.0.0
# ODOO_SERVICE_URL=http://localhost:3002
# DATA_DIR=/opt/render/project/src/data
